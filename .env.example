# Local development
# DATABASE_URL="file:./dev.db"

# Docker / production (SQLite on persistent volume)
DATABASE_URL="file:/data/prod.db"

# JWT signing (min 32 characters). Required in production.
AUTH_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=3000

# Seed passwords (change before first deploy)
SEED_ADMIN_PASSWORD="change-admin-password"
SEED_VIEWER_PASSWORD="change-viewer-password"
SEED_MANAGER_PASSWORD="change-manager-password"
